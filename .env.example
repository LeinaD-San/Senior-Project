# Postgres (default matches docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/travelagent

# Google Places / Maps (server-side)
GOOGLE_MAPS_API_KEY=

# Google Maps JS (optional; if omitted the app falls back to GOOGLE_MAPS_API_KEY)
GOOGLE_MAPS_JS_API_KEY=

# OpenAI (required for /ai/* endpoints)
OPENAI_API_KEY=
